#!/usr/bin/env bash
# pre-commit hook — scans staged changes for secrets before allowing
# the commit. Installed via `scripts/install-hooks.sh`.
#
# This hook is intentionally lenient about gitleaks being missing: prints
# a one-line warning and lets the commit proceed. The CI workflow scans
# every PR regardless, so a missing local install isn't a foot-gun.

set -e

if ! command -v gitleaks >/dev/null 2>&1; then
  printf '\033[33mwarning:\033[0m gitleaks not installed locally; secrets scan SKIPPED for this commit.\n'
  printf '  Install: https://github.com/gitleaks/gitleaks#installing\n'
  printf '  CI still scans on every push/PR.\n'
  exit 0
fi

# Stage-only scan — fast, only looks at what's about to be committed.
if ! gitleaks protect --staged --redact --verbose --no-banner; then
  printf '\n\033[31mERROR:\033[0m gitleaks found potential secrets in your staged changes.\n'
  printf '\n'
  printf 'Options:\n'
  printf '  1. Remove the secret from the file and re-stage:\n'
  printf '       git restore --staged <file>; $EDITOR <file>; git add <file>\n'
  printf '  2. If it'\''s a legitimate test fixture, allowlist it in .gitleaks.toml:\n'
  printf '       add a regex or path pattern to the [allowlist] block.\n'
  printf '  3. If gitleaks is wrong (rare), add the fingerprint to .gitleaksignore.\n'
  printf '  4. To bypass JUST THIS COMMIT in a genuine emergency:\n'
  printf '       git commit --no-verify   # leaves a trace in commit metadata\n'
  printf '\n'
  exit 1
fi

exit 0
